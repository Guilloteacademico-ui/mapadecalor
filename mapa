function drawSparkline(canvas,data,chg){
  const W=canvas.offsetWidth||canvas.parentElement.offsetWidth||300;
  const H=canvas.offsetHeight||canvas.parentElement.offsetHeight||80;
  canvas.width=W*devicePixelRatio;canvas.height=H*devicePixelRatio;
  const ctx=canvas.getContext('2d');ctx.scale(devicePixelRatio,devicePixelRatio);
  let pts=data&&data.length>2?data:(()=>{const arr=[];let v=100;for(let i=0;i<32;i++){v+=(Math.random()-.48)*1.2+(chg>0?.08:-.08);arr.push(v)}return arr})();
  const min=Math.min(...pts),max=Math.max(...pts);
  const norm=v=>H-4-((v-min)/(max-min||1))*(H-8);
  const color=chg>=0?'#30d158':'#ff453a';
  const cf=chg>=0?'rgba(48,209,88,':'rgba(255,69,58,';
  const grad=ctx.createLinearGradient(0,0,0,H);
  grad.addColorStop(0,cf+'0.22)');grad.addColorStop(1,cf+'0)');
  ctx.beginPath();
  pts.forEach((v,i)=>{const x=(i/(pts.length-1))*W,y=norm(v);i===0?ctx.moveTo(x,y):ctx.lineTo(x,y)});
  ctx.strokeStyle=color;ctx.lineWidth=2;ctx.lineJoin='round';ctx.stroke();
  ctx.lineTo(W,H);ctx.lineTo(0,H);ctx.closePath();ctx.fillStyle=grad;ctx.fill();
}

function openSectionModal(key){
  const configs={
    heatmap:{title:'S&P 500 — Heat Map',rows:()=>SP500_TICKERS.map(t=>{const d=state.stocks[t];return{ticker:t,name:'',val:d?pct(d.chg):'—',up:(d?.chg??0)>=0,price:d?'$'+fmtPrice(d.price):'—',cb:`openStockModal('${t}');closeSectionModal()`}})},
    sectors:{title:'Sectores — Performance',rows:()=>Object.entries(SECTOR_MAP).map(([name,tickers])=>{const chgs=tickers.map(t=>state.stocks[t]?.chg).filter(c=>c!=null);const avg=chgs.length?chgs.reduce((a,b)=>a+b,0)/chgs.length:0;return{ticker:'',name,val:pct(avg),up:avg>=0,price:'',cb:''}}).sort((a,b)=>parseFloat(b.val)-parseFloat(a.val))},
    gainers:{title:'Top Gainers',rows:()=>SP500_TICKERS.map(t=>({t,...state.stocks[t]})).filter(s=>s.price).sort((a,b)=>b.chg-a.chg).slice(0,20).map(d=>({ticker:d.t,name:'',val:pct(d.chg),up:true,price:'$'+fmtPrice(d.price),cb:`openStockModal('${d.t}');closeSectionModal()`}))},
    losers:{title:'Top Losers',rows:()=>SP500_TICKERS.map(t=>({t,...state.stocks[t]})).filter(s=>s.price).sort((a,b)=>a.chg-b.chg).slice(0,20).map(d=>({ticker:d.t,name:'',val:pct(d.chg),up:false,price:'$'+fmtPrice(d.price),cb:`openStockModal('${d.t}');closeSectionModal()`}))},
    futures:{title:'Futuros',rows:()=>FUTURES_SYMS.map(f=>{const d=state.futures[f.label];return{ticker:f.label,name:'',val:d?pct(d.chg):'—',up:(d?.chg??0)>=0,price:d?fmtPrice(d.price):'—',cb:''}})},
    forex:{title:'Forex & Crypto',rows:()=>[...FOREX_PAIRS.map(p=>{const d=state.forex[p];return{ticker:d?.label||p,name:'',val:d?pct(d.chg):'—',up:(d?.chg??0)>=0,price:d?.display||'—',cb:''}}),...CRYPTO_SYMS.map(s=>{const d=state.crypto[s];return{ticker:s,name:'Coinbase',val:d?pct(d.chg):'—',up:(d?.chg??0)>=0,price:d?'$'+fmtPrice(d.price):'—',cb:`openCryptoModal('${s}');closeSectionModal()`}})]},
    news:{title:'Últimas Noticias',rows:()=>state.news.map(n=>({ticker:(n.ticker||'MKT').substring(0,5),name:n.source,val:n.time,up:true,price:'',cb:`window.open('${n.url}','_blank')`}))},
    markets:{title:'Mercados',rows:()=>[...MARKET_SYMS,'GLD','USO','TLT'].map(s=>{const d=state.stocks[s];return{ticker:s,name:'',val:d?pct(d.chg):'—',up:(d?.chg??0)>=0,price:d?'$'+fmtPrice(d.price):'—',cb:`openStockModal('${s}');closeSectionModal()`}})},
    calendar:{title:'Calendario Económico',rows:()=>[{day:'Esta semana',imp:'high',txt:'FOMC Meeting Minutes'},{day:'Esta semana',imp:'high',txt:'Initial Jobless Claims — 08:30 ET'},{day:'Esta semana',imp:'med',txt:'PPI Final Demand'},{day:'Próx. semana',imp:'high',txt:'CPI YoY — 08:30 ET'},{day:'Próx. semana',imp:'high',txt:'Retail Sales — 08:30 ET'},{day:'Próx. semana',imp:'med',txt:'UMich Consumer Sentiment'}].map(e=>({ticker:e.day,name:e.txt,val:e.imp==='high'?'●● Alto':e.imp==='med'?'● Medio':'○ Bajo',up:e.imp==='high',price:'',cb:''}))},
  };
  const cfg=configs[key];if(!cfg)return;
  document.getElementById('section-modal-title').textContent=cfg.title;
  const rows=cfg.rows();
  document.getElementById('section-modal-body').innerHTML=rows.map((r,i)=>`<div style="background:#2c2c2e;border-bottom:.5px solid var(--border);padding:10px 0;display:flex;align-items:center;gap:10px;${i===0?'border-radius:12px 12px 0 0':''}${i===rows.length-1?'border-radius:0 0 12px 12px;border-bottom:none':''}${r.cb?'cursor:pointer':''}" ${r.cb?`onclick="${r.cb}"`:''}><span style="font-size:13px;font-weight:700;color:var(--blue);width:60px;flex-shrink:0">${r.ticker}</span><span style="font-size:12px;color:var(--muted);flex:1">${r.name||r.price}</span><span style="font-size:13px;font-weight:700;${r.up?'color:var(--green)':'color:var(--red)'}">${r.val}</span></div>`).join('');
  document.getElementById('section-overlay').classList.add('open');
  stopUpdates();
}

function closeSectionModal(){document.getElementById('section-overlay').classList.remove('open');startUpdates()}
document.getElementById('section-modal-close').addEventListener('click',closeSectionModal);
document.getElementById('section-overlay').addEventListener('click',e=>{if(e.target===document.getElementById('section-overlay'))closeSectionModal()});

document.querySelectorAll('.sec-link').forEach(link=>{
  link.addEventListener('click',e=>{e.preventDefault();const key=link.dataset.key;if(key)openSectionModal(key)});
});

function startUpdates(){
  if(updateTimer)return;
  isActive=true;
  updateTimer=setInterval(fetchAll,UPDATE_MS);
  animateProgress();
}
function stopUpdates(){
  isActive=false;clearInterval(updateTimer);updateTimer=null;
  const bar=document.getElementById('refresh-bar');bar.style.transition='none';bar.style.width='0%';
}
function animateProgress(){
  const bar=document.getElementById('refresh-bar');bar.style.transition='none';bar.style.width='0%';bar.offsetHeight;
  bar.style.transition=`width ${UPDATE_MS}ms linear`;bar.style.width='100%';
}

document.addEventListener('visibilitychange',()=>{
  if(document.visibilityState==='visible'){fetchAll();startUpdates();animateProgress()}
  else stopUpdates();
});
window.addEventListener('focus',()=>{fetchAll();startUpdates()});
window.addEventListener('blur',stopUpdates);
window.addEventListener('pageshow',()=>{fetchAll();startUpdates()});
window.addEventListener('pagehide',stopUpdates);

document.querySelectorAll('.tab-item').forEach(tab=>{
  tab.addEventListener('click',()=>{
    document.querySelectorAll('.tab-item').forEach(t=>t.classList.remove('active'));
    tab.classList.add('active');
    const anchor=document.getElementById(tab.dataset.target);
    const scrollEl=document.getElementById('scroll-body');
    if(anchor&&scrollEl){const top=anchor.getBoundingClientRect().top-scrollEl.getBoundingClientRect().top+scrollEl.scrollTop-8;scrollEl.scrollTo({top:Math.max(0,top),behavior:'smooth'})}
  });
});

fetchAll();
startUpdates();

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover, maximum-scale=1.0, user-scalable=no">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<title>Finviz Live</title>
<style>
:root {
  --bg:#0a0a0a;--bg2:#111111;--bg3:#1a1a1a;--bg4:#222222;
  --border:#2a2a2a;--text:#e0e0e0;--muted:#666;
  --green:#30d158;--red:#ff453a;--blue:#64d2ff;--accent:#32d74b;
  --safe-top:env(safe-area-inset-top,54px);
  --safe-bot:env(safe-area-inset-bottom,34px);
  --tab-h:calc(56px + var(--safe-bot));
}
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent}
html,body{background:var(--bg);color:var(--text);font-family:-apple-system,'SF Pro Text','Helvetica Neue',sans-serif;font-size:13px;height:100%;overscroll-behavior:none}
.status-bar{height:var(--safe-top);background:var(--bg2);position:sticky;top:0;z-index:100}
.top-header{background:rgba(17,17,17,.94);backdrop-filter:blur(20px) saturate(180%);-webkit-backdrop-filter:blur(20px) saturate(180%);border-bottom:.5px solid var(--border);padding:8px 16px;position:sticky;top:var(--safe-top);z-index:99;display:flex;align-items:center;justify-content:space-between}
.logo{font-size:18px;font-weight:800;color:var(--accent);letter-spacing:.5px}
.header-right{display:flex;flex-direction:column;align-items:flex-end;gap:2px}
.live-badge{display:flex;align-items:center;gap:5px;font-size:11px;color:var(--muted)}
.live-dot{width:7px;height:7px;border-radius:50%;background:var(--green);animation:pulse 2s infinite}
.live-dot.paused{background:var(--muted);animation:none}
.live-dot.loading{background:#ff9f0a;animation:pulse .5s infinite}
@keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.4;transform:scale(.8)}}
.last-update{font-size:10px;color:var(--muted)}
.refresh-bar{height:2px;background:var(--bg2);overflow:hidden}
.refresh-progress{height:100%;background:linear-gradient(90deg,var(--accent),transparent);width:0%;transition:width linear}
.tape-outer{background:var(--bg2);border-bottom:.5px solid var(--border);overflow:hidden;height:32px;display:flex;align-items:center}
.tape-track{display:flex;gap:28px;padding:0 16px;animation:scroll-tape 32s linear infinite;white-space:nowrap;min-width:200%}
@keyframes scroll-tape{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}
.tape-item{display:flex;gap:6px;align-items:center}
.tape-sym{font-size:11px;font-weight:600;color:#bbb}
.tape-val{font-size:11px;font-weight:700}
.tape-chg{font-size:10px;font-weight:600}
.up{color:var(--green)}.dn{color:var(--red)}
.scroll-body{overflow-y:auto;overflow-x:hidden;-webkit-overflow-scrolling:touch;height:calc(100dvh - var(--safe-top) - 40px - 32px - var(--tab-h));padding-bottom:12px}
.sec-hdr{padding:14px 16px 6px;display:flex;justify-content:space-between;align-items:baseline}
.sec-title{font-size:15px;font-weight:700;letter-spacing:-.2px}
.sec-link{font-size:12px;color:var(--accent);text-decoration:none;font-weight:500}
.market-pills{display:flex;gap:8px;padding:0 16px 10px;overflow-x:auto;scrollbar-width:none}
.market-pills::-webkit-scrollbar{display:none}
.mpill{background:var(--bg3);border:.5px solid var(--border);border-radius:12px;padding:7px 12px;min-width:82px;flex-shrink:0;text-align:center;cursor:pointer}
.mpill:active{background:var(--bg4)}
.mpill-sym{font-size:10px;color:var(--muted);margin-bottom:2px}
.mpill-val{font-size:14px;font-weight:700}
.mpill-chg{font-size:11px;font-weight:600;margin-top:1px}
.heatmap-section{padding:0 10px 10px}
.heatmap-grid{display:grid;grid-template-columns:repeat(7,1fr);gap:3px}
.hm-cell{aspect-ratio:1.1;border-radius:6px;display:flex;flex-direction:column;align-items:center;justify-content:center;cursor:pointer;padding:2px;transition:transform .12s}
.hm-cell:active{transform:scale(.92)}
.hm-ticker{font-size:9px;font-weight:700;color:rgba(255,255,255,.9);line-height:1}
.hm-chg{font-size:8px;color:rgba(255,255,255,.72);margin-top:1px;line-height:1}
.c-5{background:#7f1a1a}.c-4{background:#9e2020}.c-3{background:#c02828}
.c-2{background:#d84040}.c-1{background:#a05050}.c0{background:#252525}
.cp1{background:#1b5c2c}.cp2{background:#1d7530}.cp3{background:#219438}
.cp4{background:#25b344}.cp5{background:#2ed158}
.sector-list{padding:0 16px;display:flex;flex-direction:column;gap:6px}
.sector-row{background:var(--bg3);border-radius:10px;padding:8px 12px;display:flex;align-items:center;gap:10px}
.sector-name{font-size:12px;color:var(--muted);width:110px;flex-shrink:0}
.sector-bar-wrap{flex:1;height:5px;background:var(--bg4);border-radius:3px;overflow:hidden}
.sector-bar{height:100%;border-radius:3px;transition:width .6s}
.sector-val{font-size:13px;font-weight:700;width:52px;text-align:right}
.signals-list{padding:0 16px;display:flex;flex-direction:column;gap:0}
.sig-row{background:var(--bg3);border-bottom:.5px solid var(--border);padding:9px 12px;display:flex;align-items:center;cursor:pointer}
.sig-row:first-child{border-radius:10px 10px 0 0}
.sig-row:last-child{border-radius:0 0 10px 10px;border-bottom:none}
.sig-row:active{background:var(--bg4)}
.sig-ticker{font-size:13px;font-weight:700;color:var(--blue);width:52px}
.sig-price{font-size:12px;flex:1}
.sig-chg{font-size:13px;font-weight:700;width:58px;text-align:right}
.sig-tag{font-size:9px;color:var(--muted);background:var(--bg4);border:.5px solid var(--border);padding:2px 5px;border-radius:4px;margin-left:6px;white-space:nowrap}
.horiz-cards{display:flex;gap:8px;padding:0 16px;overflow-x:auto;scrollbar-width:none}
.horiz-cards::-webkit-scrollbar{display:none}
.hcard{background:var(--bg3);border:.5px solid var(--border);border-radius:10px;padding:8px 11px;min-width:82px;flex-shrink:0;text-align:center;cursor:pointer}
.hcard:active{background:var(--bg4)}
.hcard-name{font-size:9px;color:var(--muted);margin-bottom:3px}
.hcard-price{font-size:13px;font-weight:700}
.hcard-chg{font-size:10px;font-weight:600;margin-top:2px}
.news-list{padding:0 16px;display:flex;flex-direction:column;gap:0}
.news-item{background:var(--bg3);border-bottom:.5px solid var(--border);padding:10px 12px;display:flex;gap:9px;align-items:flex-start;cursor:pointer}
.news-item:first-child{border-radius:10px 10px 0 0}
.news-item:last-child{border-radius:0 0 10px 10px;border-bottom:none}
.news-item:active{background:var(--bg4)}
.news-badge{background:#1e3a1e;color:var(--green);font-size:9px;font-weight:700;padding:2px 5px;border-radius:4px;white-space:nowrap;min-width:34px;text-align:center;flex-shrink:0;margin-top:1px}
.news-headline{font-size:12px;line-height:1.35}
.news-meta{font-size:10px;color:var(--muted);margin-top:3px}
.stats-row{display:flex;gap:0;padding:0 16px 10px;overflow-x:auto;scrollbar-width:none}
.stats-row::-webkit-scrollbar{display:none}
.stat-pill{background:var(--bg3);border:.5px solid var(--border);border-radius:10px;padding:7px 11px;margin-right:7px;flex-shrink:0}
.stat-lbl{font-size:9px;color:var(--muted);margin-bottom:2px}
.stat-val{font-size:13px;font-weight:700}
.error-banner{background:#3a1a1a;border:.5px solid var(--red);border-radius:8px;margin:8px 16px;padding:8px 12px;font-size:11px;color:#ff8a80;display:none}
.skeleton{background:linear-gradient(90deg,var(--bg3) 25%,var(--bg4) 50%,var(--bg3) 75%);background-size:200% 100%;animation:shimmer 1.5s infinite;border-radius:6px}
@keyframes shimmer{0%{background-position:200% 0}100%{background-position:-200% 0}}
.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.65);backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px);z-index:500;display:flex;align-items:flex-end;opacity:0;pointer-events:none;transition:opacity .25s}
.modal-overlay.open{opacity:1;pointer-events:all}
.modal-sheet{width:100%;background:#1c1c1e;border-radius:20px 20px 0 0;padding-bottom:var(--safe-bot);transform:translateY(100%);transition:transform .3s cubic-bezier(.32,0,.67,0);max-height:88vh;overflow-y:auto;-webkit-overflow-scrolling:touch}
.modal-overlay.open .modal-sheet{transform:translateY(0);transition:transform .35s cubic-bezier(.22,1,.36,1)}
.modal-handle{width:36px;height:4px;background:#48484a;border-radius:2px;margin:10px auto 6px}
.modal-header{padding:8px 20px 12px;display:flex;justify-content:space-between;align-items:flex-start;border-bottom:.5px solid var(--border)}
.modal-ticker{font-size:26px;font-weight:800;letter-spacing:-.5px}
.modal-name{font-size:12px;color:var(--muted);margin-top:2px}
.modal-close{width:30px;height:30px;background:#3a3a3c;border-radius:50%;border:none;color:#aaa;font-size:16px;cursor:pointer;display:flex;align-items:center;justify-content:center}
.modal-price-row{padding:14px 20px 4px;display:flex;align-items:baseline;gap:12px}
.modal-price{font-size:32px;font-weight:700;letter-spacing:-.5px}
.modal-chg-badge{font-size:16px;font-weight:600;padding:3px 10px;border-radius:8px}
.modal-chg-badge.up{background:rgba(48,209,88,.18);color:var(--green)}
.modal-chg-badge.dn{background:rgba(255,69,58,.18);color:var(--red)}
.modal-stats-grid{display:grid;grid-template-columns:1fr 1fr;gap:1px;background:var(--border);margin:14px 20px;border-radius:12px;overflow:hidden}
.modal-stat{background:#2c2c2e;padding:10px 14px}
.modal-stat-lbl{font-size:11px;color:var(--muted);margin-bottom:3px}
.modal-stat-val{font-size:14px;font-weight:600}
.modal-mini-chart{margin:0 20px 14px;background:#2c2c2e;border-radius:12px;overflow:hidden;height:80px}
.modal-action-row{display:flex;gap:10px;padding:0 20px 16px}
.modal-btn{flex:1;padding:13px;border-radius:12px;border:none;font-size:14px;font-weight:600;cursor:pointer;font-family:-apple-system,sans-serif}
.modal-btn:active{opacity:.7}
.modal-btn-primary{background:var(--accent);color:#000}
.modal-btn-secondary{background:#3a3a3c;color:var(--text)}
.tab-bar{position:fixed;bottom:0;left:0;right:0;height:var(--tab-h);background:rgba(17,17,17,.94);backdrop-filter:blur(20px) saturate(180%);-webkit-backdrop-filter:blur(20px) saturate(180%);border-top:.5px solid var(--border);display:flex;z-index:200;padding-bottom:var(--safe-bot)}
.tab-item{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:3px;cursor:pointer;padding-top:6px;-webkit-user-select:none}
.tab-item:active{opacity:.5;transform:scale(.93)}
.tab-icon{width:26px;height:26px;display:flex;align-items:center;justify-content:center}
.tab-icon svg{width:24px;height:24px;fill:var(--muted);stroke:var(--muted);transition:fill .15s,stroke .15s}
.tab-label{font-size:10px;font-weight:500;color:var(--muted);transition:color .15s}
.tab-item.active .tab-icon svg{fill:var(--accent);stroke:var(--accent)}
.tab-item.active .tab-label{color:var(--accent);font-weight:600}
.section-gap{height:10px}
@keyframes toastIn{from{opacity:0;transform:translateX(-50%) translateY(10px)}to{opacity:1;transform:translateX(-50%) translateY(0)}}
</style>
</head>

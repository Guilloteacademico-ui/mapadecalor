  document.getElementById('tape-track').innerHTML=[...valid,...valid].map(i=>`<div class="tape-item"><span class="tape-sym">${i.sym}</span><span class="tape-val">${fmtPrice(i.data.price)}</span><span class="tape-chg ${i.data.chg>=0?'up':'dn'}">${pct(i.data.chg)}</span></div>`).join('');
}


<script>
const FINNHUB_KEY='d7fq5l9r01qqb8rh6vagd7fq5l9r01qqb8rh6vb0';
const UPDATE_MS=30000;

const SP500_TICKERS=['NVDA','AAPL','MSFT','AMZN','GOOGL','META','TSLA','BRK.B','JPM','LLY','AVGO','V','UNH','MA','XOM','COST','HD','PG','JNJ','ABBV','WMT','BAC','MRK','ORCL','CVX','KO','PEP','AMD','NFLX','ADBE','CRM','ACN','TXN','LIN','MCD','HON','IBM','QCOM','GE','CAT','AXP','ISRG','SBUX','BA','NKE','INTC','PFE','MRNA','PYPL'];
const MARKET_SYMS=['SPY','QQQ','DIA','IWM','VIX'];
const FUTURES_SYMS=[{label:'ES',yahoo:'ES=F'},{label:'NQ',yahoo:'NQ=F'},{label:'YM',yahoo:'YM=F'},{label:'RTY',yahoo:'RTY=F'},{label:'CL',yahoo:'CL=F'},{label:'GC',yahoo:'GC=F'},{label:'SI',yahoo:'SI=F'},{label:'ZB',yahoo:'ZB=F'}];
const CRYPTO_SYMS=['BTC','ETH','SOL','BNB'];
const FOREX_PAIRS=['EUR','GBP','JPY','CHF','ARS','BRL'];
const SECTOR_MAP={'Technology':['NVDA','AAPL','MSFT','AVGO','AMD','ORCL','IBM','QCOM','TXN','INTC','ADBE','CRM','ACN'],'Comm. Services':['GOOGL','META','NFLX'],'Financials':['JPM','V','MA','BAC','AXP'],'Consumer Disc.':['AMZN','TSLA','MCD','SBUX','NKE','HD'],'Healthcare':['LLY','UNH','JNJ','ABBV','MRK','PFE','MRNA','ISRG'],'Industrials':['HON','GE','CAT','BA'],'Energy':['XOM','CVX'],'Consumer Stap.':['WMT','KO','PEP','PG','COST'],'Materials':['LIN']};

let state={stocks:{},futures:{},crypto:{},forex:{},news:[],loaded:false};
let updateTimer=null,isActive=true;

function pct(c){return(c>=0?'+':'')+c.toFixed(2)+'%'}
function fmtPrice(n){if(!n||isNaN(n))return'—';if(n>=10000)return n.toLocaleString('en-US',{maximumFractionDigits:0});if(n>=1000)return n.toLocaleString('en-US',{maximumFractionDigits:2});if(n>=10)return n.toFixed(2);return n.toFixed(2)}
function safeId(t){return t.replace(/[^a-zA-Z0-9]/g,'_')}
function colorClass(c){if(c<=-4)return'c-5';if(c<=-3)return'c-4';if(c<=-2)return'c-3';if(c<=-1)return'c-2';if(c<0)return'c-1';if(c===0)return'c0';if(c<1)return'cp1';if(c<2)return'cp2';if(c<3)return'cp3';if(c<4)return'cp4';return'cp5'}
function nowTime(){return new Date().toLocaleTimeString('en-US',{hour:'2-digit',minute:'2-digit',second:'2-digit'})}
function calcChg(price,prev){if(!prev||prev===0)return 0;return((price-prev)/prev)*100}
function sleep(ms){return new Promise(r=>setTimeout(r,ms))}

async function fetchFinnhubQuote(symbol){
  const r=await fetch(`https://finnhub.io/api/v1/quote?symbol=${encodeURIComponent(symbol)}&token=${FINNHUB_KEY}`,{signal:AbortSignal.timeout(8000)});
  if(!r.ok)throw new Error(r.status);
  return r.json();
}

async function fetchAllStocks(){
  const allSyms=[...new Set([...SP500_TICKERS,...MARKET_SYMS])];
  const results={};
  const BATCH=10;
  for(let i=0;i<allSyms.length;i+=BATCH){
    const batch=allSyms.slice(i,i+BATCH);
    const settled=await Promise.allSettled(batch.map(sym=>fetchFinnhubQuote(sym)));
    settled.forEach((res,idx)=>{
      const sym=batch[idx];
      if(res.status==='fulfilled'){
        const d=res.value;
        if(d&&d.c){results[sym]={price:d.c,prev:d.pc,open:d.o,high:d.h,low:d.l,chg:calcChg(d.c,d.pc)}}
      }
    });
    if(i+BATCH<allSyms.length)await sleep(700);
  }
  return results;
}

async function fetchFutures(){
  const results={};
  const proxies=[
    s=>`https://api.allorigins.win/raw?url=${encodeURIComponent(`https://query1.finance.yahoo.com/v8/finance/chart/${s}?interval=1d&range=2d`)}`,
    s=>`https://corsproxy.io/?${encodeURIComponent(`https://query1.finance.yahoo.com/v8/finance/chart/${s}?interval=1d&range=2d`)}`,
  ];
  for(const fut of FUTURES_SYMS){
    for(const proxy of proxies){
      try{
        const r=await fetch(proxy(fut.yahoo),{signal:AbortSignal.timeout(6000)});
        if(!r.ok)continue;
        const data=JSON.parse(await r.text());
        const meta=data?.chart?.result?.[0]?.meta;
        if(meta?.regularMarketPrice){
          results[fut.label]={price:meta.regularMarketPrice,prev:meta.chartPreviousClose||meta.previousClose,chg:calcChg(meta.regularMarketPrice,meta.chartPreviousClose||meta.previousClose)};
          break;
        }
      }catch(e){}
    }
  }
  return results;
}

async function fetchCrypto(){
  const results={};
  await Promise.allSettled(CRYPTO_SYMS.map(async sym=>{
    try{
      const r=await fetch(`https://api.coinbase.com/v2/prices/${sym}-USD/spot`,{signal:AbortSignal.timeout(5000)});
      if(!r.ok)return;
      const d=await r.json();
      const price=parseFloat(d?.data?.amount);
      if(price){const prev=state.crypto[sym]?.price||price;results[sym]={price,prev,chg:state.crypto[sym]?.price?calcChg(price,state.crypto[sym].price):0}}
    }catch(e){}
  }));
  return results;
}

async function fetchForex(){
  try{
    const r=await fetch('https://open.er-api.com/v6/latest/USD',{signal:AbortSignal.timeout(6000)});
    if(!r.ok)throw new Error();
    const d=await r.json();
    const rates=d.rates||{};
    const results={};
    FOREX_PAIRS.forEach(pair=>{
      if(rates[pair]){
        const rate=rates[pair];
        results[pair]={rate,display:pair==='JPY'?rate.toFixed(2):(1/rate).toFixed(4),label:pair==='JPY'?`USD/${pair}`:`${pair}/USD`,chg:state.forex[pair]?.rate?calcChg(rate,state.forex[pair].rate):0};
      }
    });
    return results;
  }catch(e){return{}}
}

async function fetchNews(){
  try{
    const r=await fetch(`https://finnhub.io/api/v1/news?category=general&token=${FINNHUB_KEY}`,{signal:AbortSignal.timeout(6000)});
    if(!r.ok)throw new Error();
    const items=await r.json();
    return items.slice(0,12).map(n=>({ticker:n.related||'MKT',headline:n.headline,source:n.source,url:n.url,time:new Date(n.datetime*1000).toLocaleTimeString('en-US',{hour:'2-digit',minute:'2-digit'})}));
  }catch(e){return[]}
}

async function fetchCandles(symbol){
  const to=Math.floor(Date.now()/1000);
  const from=to-86400;
  try{
    const r=await fetch(`https://finnhub.io/api/v1/stock/candle?symbol=${encodeURIComponent(symbol)}&resolution=15&from=${from}&to=${to}&token=${FINNHUB_KEY}`,{signal:AbortSignal.timeout(6000)});
    if(!r.ok)return null;
    const d=await r.json();
    return d.s==='ok'?d.c:null;
  }catch(e){return null}
}

async function fetchAll(){
  setStatus('loading');
  try{
    const [stocks,futures,crypto,forex,news]=await Promise.allSettled([fetchAllStocks(),fetchFutures(),fetchCrypto(),fetchForex(),fetchNews()]);
    if(stocks.status==='fulfilled'&&Object.keys(stocks.value).length>0)state.stocks=stocks.value;
    if(futures.status==='fulfilled')state.futures={...state.futures,...futures.value};
    if(crypto.status==='fulfilled')state.crypto={...state.crypto,...crypto.value};
    if(forex.status==='fulfilled')state.forex={...state.forex,...forex.value};
    if(news.status==='fulfilled'&&news.value.length>0)state.news=news.value;
    if(Object.keys(state.stocks).length>0){
      state.loaded=true;
      renderAll();
      setStatus('live');
      document.getElementById('last-update').textContent='Actualizado '+nowTime();
      document.getElementById('error-banner').style.display='none';
    }else{
      setStatus('paused');
      showError('No se pudieron cargar datos. Verificá la conexión.');
    }
  }catch(e){
    setStatus('paused');
    showError('Error al cargar datos. Reintentando…');
  }
}

function setStatus(s){
  const dot=document.getElementById('live-dot');
  const lbl=document.getElementById('live-label');
  dot.className='live-dot';
  if(s==='live'){lbl.textContent='LIVE'}
  if(s==='loading'){dot.classList.add('loading');lbl.textContent='CARGANDO'}
  if(s==='paused'){dot.classList.add('paused');lbl.textContent='PAUSADO'}
}
function showError(msg){const b=document.getElementById('error-banner');b.textContent='⚠ '+msg;b.style.display='block'}

